{
    "name": "grok-config-switcher",
    "version": "1.6.3",
    "description": "Grok Go - Windows desktop provider switcher for Grok Build",
    "main": "dist-electron/main/main.js",
    "author": "501498318-eng",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm:dev:electron\"",
        "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
        "build": "npm run typecheck && vite build && npm run build:electron",
        "build:electron": "node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
        "dist": "npm run test && npm run build && electron-builder --win nsis zip",
        "dist:installer": "npm run test && npm run build && electron-builder --win nsis",
        "dist:zip": "npm run test && npm run build && electron-builder --win zip",
        "preview": "vite preview --host 127.0.0.1"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1",
        "smol-toml": "^1.3.1",
        "write-file-atomic": "^6.0.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.49.1",
        "@types/node": "^22.10.2",
        "@types/react": "^19.0.2",
        "@types/react-dom": "^19.0.2",
        "@vitejs/plugin-react": "^4.3.4",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "electron": "^33.2.1",
        "electron-builder": "^25.1.8",
        "lucide-react": "^0.468.0",
        "rcedit": "5.0.2",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "typescript": "^5.7.2",
        "vite": "^6.0.3",
        "vitest": "^2.1.8",
        "wait-on": "^8.0.1"
    },
    "build": {
        "appId": "com.xuhao.grok-config-switcher",
        "productName": "Grok Go",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "dist-electron/**/*",
            "!dist-electron/**/*.test.js",
            "!dist-electron/**/*.map",
            "assets/**/*",
            "package.json"
        ],
        "extraFiles": [
            "LICENSE",
            "README.md"
        ],
        "afterPack": "scripts/after-pack.cjs",
        "asar": true,
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico",
            "signAndEditExecutable": false,
            "artifactName": "Grok-Go-${version}-win-${arch}.${ext}"
        },
        "nsis": {
            "artifactName": "Grok-Go-${version}-Setup-${arch}.${ext}",
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Grok Go",
            "deleteAppDataOnUninstall": false,
            "license": "LICENSE"
        }
    },
    "packageManager": "pnpm@10.12.1"
}

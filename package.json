{
    "name":  "grok-config-switcher",
    "version":  "1.6.0",
    "description":  "Grok Go - Windows desktop provider switcher for Grok Build",
    "main":  "dist-electron/main/main.js",
    "author":  "501498318-eng",
    "license":  "MIT",
    "type":  "module",
    "scripts":  {
                    "dev":  "concurrently -k \"vite --host 127.0.0.1\" \"npm:dev:electron\"",
                    "dev:electron":  "wait-on tcp:5173 \u0026\u0026 cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
                    "build":  "npm run typecheck \u0026\u0026 vite build \u0026\u0026 npm run build:electron",
                    "build:electron":  "node -e \"require(\u0027node:fs\u0027).rmSync(\u0027dist-electron\u0027,{recursive:true,force:true})\" \u0026\u0026 tsc -p tsconfig.electron.json",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "typecheck":  "tsc --noEmit \u0026\u0026 tsc -p tsconfig.electron.json --noEmit",
                    "dist":  "npm run test \u0026\u0026 npm run build \u0026\u0026 electron-builder --win portable",
                    "preview":  "vite preview --host 127.0.0.1"
                },
    "dependencies":  {
                         "lucide-react":  "^0.468.0",
                         "jsonc-parser":  "^3.3.1",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "smol-toml":  "^1.3.1",
                         "write-file-atomic":  "^6.0.0"
                     },
    "devDependencies":  {
                            "@playwright/test":  "^1.49.1",
                            "@types/node":  "^22.10.2",
                            "@types/react":  "^19.0.2",
                            "@types/react-dom":  "^19.0.2",
                            "@vitejs/plugin-react":  "^4.3.4",
                            "concurrently":  "^9.1.2",
                            "cross-env":  "^7.0.3",
                            "electron":  "^33.2.1",
                            "electron-builder":  "^25.1.8",
                            "typescript":  "^5.7.2",
                            "vite":  "^6.0.3",
                            "vitest":  "^2.1.8",
                            "wait-on":  "^8.0.1"
                        },
    "build":  {
                  "appId":  "com.xuhao.grok-config-switcher",
                  "productName":  "Grok Go",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/**/*",
                                "dist-electron/**/*",
                                "assets/**/*",
                                "package.json"
                            ],
                  "asar":  true,
                  "win":  {
                              "target":  "portable",
                              "icon":  "assets/icon.ico",
                              "signAndEditExecutable":  false,
                              "artifactName":  "Grok-Go-${version}-portable.${ext}"
                          }
              },
    "packageManager":  "pnpm@10.12.1"
}
